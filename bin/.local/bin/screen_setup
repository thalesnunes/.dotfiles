#!/usr/bin/env bash

case "$XDG_SESSION_DESKTOP" in
    Hyprland)
        WM_DIR="hypr"
        CONF_EXT="lua"
        ;;
    sway|mango)
        WM_DIR="$XDG_SESSION_DESKTOP"
        CONF_EXT="conf"
        ;;
esac

OUTPUTS_DIR="$XDG_CONFIG_HOME/$WM_DIR/outputs"

if [ -n "$1" ]; then
    screen_profile="$1"
    primary_monitor="$2"
    secondary_monitor="$3"
else
    source $XDG_USER_BIN/screen_profile_selector
fi

sed "s/:PRIMARY_MONITOR/$primary_monitor/g; s/:SECONDARY_MONITOR/$secondary_monitor/g;" $OUTPUTS_DIR/"$screen_profile-screen.$CONF_EXT" > $OUTPUTS_DIR/screen.$CONF_EXT
notify-send -a "Desktop Setup" "Screen Setup" "$screen_profile output profile was setup"
